# === Functions ===

usage() {
    cat <<EOF
Usage: ob <command> [options] [arguments]

Commands:
  init   [<machine>]    One-click initialize OpenBMC dev environment
  status                Show current OpenBMC source binding status

Options:
  --dry-run             Print actions without executing
  --obmc-url <url>      Use a custom OpenBMC repository URL
  -v, --verbose         Verbose output
  -h, --help            Show this help

Examples:
  ob init                          # List machines and choose interactively
  ob init romulus                  # Initialize romulus machine
  ob init romulus --dry-run        # Preview what would be done
  ob init romulus --obmc-url https://example.com/openbmc.git
EOF
}

parse_args() {
    if [[ $# -lt 1 ]]; then
        usage
        exit 1
    fi

    # Handle global --help/-h before dispatching to subcommands
    if [[ "$1" == "-h" || "$1" == "--help" ]]; then
        usage
        exit 0
    fi

    COMMAND="$1"
    shift

    case "$COMMAND" in
        init)
            if [[ $# -gt 0 ]] && [[ "$1" != -* ]]; then
                MACHINE="$1"
                shift
            fi
            ;;
        status)
            if [[ $# -gt 0 ]] && [[ "$1" != -* ]]; then
                MACHINE="$1"
                shift
            fi
            ;;
        *)
            error "Unknown command: $COMMAND"
            usage
            exit 1
            ;;
    esac

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run)     DRY_RUN=1; shift ;;
            --obmc-url)
                if [[ $# -lt 2 ]]; then
                    error "Missing value for --obmc-url"
                    usage
                    exit 1
                fi
                OPENBMC_REPO_URL="$2"
                shift 2
                ;;
            -v|-V|--verbose)  VERBOSE=1; shift ;;
            -h|--help)     usage; exit 0 ;;
            *)             error "Unknown option: $1"; usage; exit 1 ;;
        esac
    done
}

is_valid_repo_url() {
    local repo_url="$1"
    [[ "$repo_url" =~ ^https?:// ]] || [[ "$repo_url" =~ ^ssh:// ]] || [[ "$repo_url" =~ ^git:// ]] || [[ "$repo_url" =~ ^git@ ]]
}

normalize_repo_url() {
    local repo_url="$1"
    local normalized="$repo_url"
    local host=""
    local path=""

    normalized="${normalized#https://}"
    normalized="${normalized#http://}"
    normalized="${normalized#ssh://}"
    normalized="${normalized#git://}"

    if [[ "$normalized" =~ ^([^@]+)@([^:]+):(.+)$ ]]; then
        host="${BASH_REMATCH[2]}"
        path="${BASH_REMATCH[3]}"
        if [[ "$path" =~ ^([0-9]+)/(.*)$ ]]; then
            normalized="$host/${path#*/}"
        else
            normalized="$host/$path"
        fi
    elif [[ "$normalized" =~ ^([^@]+)@(.+)$ ]]; then
        normalized="${BASH_REMATCH[2]}"
    fi

    if [[ "$normalized" =~ ^\[?([^]/:]+)\]?:(.+)$ ]]; then
        host="${BASH_REMATCH[1]}"
        path="${BASH_REMATCH[2]}"
        if [[ "$path" =~ ^([0-9]+)/(.*)$ ]]; then
            normalized="$host/${path#*/}"
        else
            normalized="$host/$path"
        fi
    fi

    normalized="${normalized%/}"
    normalized="${normalized%.git}"

    if [[ "$normalized" =~ ^([^/]+)/(.*)$ ]]; then
        local host="${BASH_REMATCH[1]}"
        local path="${BASH_REMATCH[2]}"
        host="${host,,}"
        path="${path,,}"
        normalized="$host/$path"
    else
        normalized="${normalized,,}"
    fi

    echo "$normalized"
}

write_source_lock() {
    local normalized_source
    local timestamp

    normalized_source="$(normalize_repo_url "$OPENBMC_REPO_URL")"
    timestamp="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

    if [[ "$DRY_RUN" -eq 1 ]]; then
        info "[DRY-RUN] Would write source lock to $SOURCE_LOCK_FILE"
        info "[DRY-RUN]   normalized_source=$normalized_source"
        info "[DRY-RUN]   origin_url=$OPENBMC_REPO_URL"
        info "[DRY-RUN]   source_label=$SOURCE_LABEL"
        return 0
    fi

    mkdir -p "$CONFIGS_DIR"

    cat > "$SOURCE_LOCK_FILE" <<EOF
# openbmc source lock — auto-generated by 'ob init', do not edit by hand
normalized_source=$normalized_source
origin_url=$OPENBMC_REPO_URL
source_label=$SOURCE_LABEL
machine_first_init=$MACHINE
created_at=$timestamp
EOF
}

ensure_bootstrap_local_conf() {
    local local_conf="$BUILD_DIR/conf/local.conf"
    local connectivity_value="${OB_CONNECTIVITY_CHECK_URIS-}"

    if [[ ! -f "$local_conf" ]]; then
        error "local.conf not found at $local_conf"
        exit 1
    fi

    if [[ -n "$connectivity_value" ]]; then
        connectivity_value=${connectivity_value//\"/\\\"}
    fi

    python3 - "$local_conf" "$connectivity_value" <<'PY'
import pathlib
import sys

local_conf = pathlib.Path(sys.argv[1])
connectivity_value = sys.argv[2]
managed_start = "# BEGIN ob init managed settings"
managed_end = "# END ob init managed settings"
managed_block = [
    managed_start,
    "# Disable OE connectivity probes by default; github fetches already validate network reachability.",
    f'CONNECTIVITY_CHECK_URIS = "{connectivity_value}"',
    managed_end,
]

content = local_conf.read_text()
lines = content.splitlines()

try:
    start = lines.index(managed_start)
    end = lines.index(managed_end, start)
    lines[start:end + 1] = managed_block
except ValueError:
    if lines and lines[-1] != "":
        lines.append("")
    lines.extend(managed_block)

local_conf.write_text("\n".join(lines) + "\n")
PY

    verbose "Ensured ob init managed local.conf settings in $local_conf"
}

read_lock_field() {
    local key="$1"

    if [[ ! -f "$SOURCE_LOCK_FILE" ]]; then
        return 1
    fi

    local line
    line=$(grep -E "^${key}=" "$SOURCE_LOCK_FILE" | head -n 1 || true)
    if [[ -z "$line" ]]; then
        return 1
    fi

    echo "${line#*=}"
}

verify_source() {
    local lock_source=""
    local current_origin=""
    local current_source=""
    local requested_url="$OPENBMC_REPO_URL"
    local requested_source=""
    local lock_label=""

    if [[ ! -d "$OPENBMC_DIR/.git" ]]; then
        return 0
    fi

    if [[ ! -f "$SOURCE_LOCK_FILE" ]]; then
        current_origin=$(git -C "$OPENBMC_DIR" remote get-url origin 2>/dev/null || true)
        if [[ -n "$current_origin" ]]; then
            OPENBMC_REPO_URL="$current_origin"
            SOURCE_LABEL=""
            write_source_lock
            if [[ -n "$requested_url" ]]; then
                requested_source=$(normalize_repo_url "$requested_url")
                current_source=$(normalize_repo_url "$current_origin")
                if [[ "$requested_source" != "$current_source" ]]; then
                    error "OpenBMC main repository source conflict detected."
                    error "  Current harness source: $current_source"
                    error "  Requested source:       $requested_source"
                    error "A harness may only bind to one OpenBMC main repository source."
                    error "To use a different source, copy openbmc-aware-harness and run ob init in the new copy."
                    exit 1
                fi
            fi
            OPENBMC_REPO_URL="$requested_url"
        else
            warn "OpenBMC main repository exists but has no origin remote; skipping source lock bootstrap."
        fi
        return 0
    fi

    lock_source=$(read_lock_field normalized_source || true)
    lock_label=$(read_lock_field source_label || true)
    current_origin=$(git -C "$OPENBMC_DIR" remote get-url origin 2>/dev/null || true)

    if [[ -n "$current_origin" ]]; then
        current_source=$(normalize_repo_url "$current_origin")
        if [[ -n "$lock_source" ]] && [[ "$current_source" != "$lock_source" ]]; then
            error "OpenBMC main repository source does not match the lock file."
            error "  Locked source:  $lock_source"
            error "  Actual origin:   $current_source"
            error "Existing openbmc origin and openbmc-source.lock have drifted, likely due to a manual change."
            error "Please verify the main repository source before continuing. If you need a different source, use a separate harness copy."
            exit 1
        fi
    else
        warn "OpenBMC main repository has no origin remote; skipping lock vs origin verification."
    fi

    if [[ -n "$OPENBMC_REPO_URL" ]]; then
        requested_source=$(normalize_repo_url "$OPENBMC_REPO_URL")
        if [[ -n "$lock_source" ]] && [[ "$requested_source" != "$lock_source" ]]; then
            error "OpenBMC main repository source conflict detected."
            error "  Current harness source: $lock_source${lock_label:+  ($lock_label)}"
            error "  Requested source:       $requested_source"
            error "A harness may only bind to one OpenBMC main repository source."
            error "To use a different source, copy openbmc-aware-harness and run ob init in the new copy."
            exit 1
        fi
    fi

    return 0
}

cmd_status() {
    local lock_exists=0
    local repo_exists=0
    local normalized_source=""
    local origin_url=""
    local source_label=""
    local machine_first_init=""
    local created_at=""
    local current_origin=""
    local current_source=""

    [[ -f "$SOURCE_LOCK_FILE" ]] && lock_exists=1
    [[ -d "$OPENBMC_DIR/.git" ]] && repo_exists=1

    if [[ "$lock_exists" -eq 1 ]]; then
        normalized_source=$(read_lock_field normalized_source || true)
        origin_url=$(read_lock_field origin_url || true)
        source_label=$(read_lock_field source_label || true)
        machine_first_init=$(read_lock_field machine_first_init || true)
        created_at=$(read_lock_field created_at || true)
    fi

    if [[ "$repo_exists" -eq 1 ]]; then
        current_origin=$(git -C "$OPENBMC_DIR" remote get-url origin 2>/dev/null || true)
        if [[ -n "$current_origin" ]]; then
            current_source=$(normalize_repo_url "$current_origin")
        fi
    fi

    echo "OpenBMC main repository binding status"

    if [[ "$lock_exists" -eq 0 ]] && [[ "$repo_exists" -eq 0 ]]; then
        echo "  Status:          Not initialized"
        echo "  Hint:            Run ob init <machine>"
        return 0
    fi

    if [[ "$lock_exists" -eq 0 ]] && [[ "$repo_exists" -eq 1 ]]; then
        echo "  Status:          Repository present without source lock"
        echo "  Current origin:  ${current_source:-<missing origin>}"
        echo "  Hint:            Re-run ob init to bootstrap openbmc-source.lock"
        return 0
    fi

    echo "  Bound source:    $normalized_source${source_label:+  ($source_label)}"
    echo "  Origin URL:      ${origin_url:-<unknown>}"
    echo "  First init:      ${machine_first_init:-<unknown>}  @ ${created_at:-<unknown>}"

    if [[ "$repo_exists" -eq 0 ]]; then
        echo "  Current origin:  Repository missing"
        echo "  Status:          Main repository not cloned or was deleted"
        return 0
    fi

    if [[ -z "$current_origin" ]]; then
        echo "  Current origin:  <missing origin>"
        echo "  Status:          Origin remote missing"
        return 0
    fi

    if [[ "$current_source" == "$normalized_source" ]]; then
        echo "  Current origin:  $current_source  (origin matches)"
        echo "  Status:          OK"
        return 0
    fi

    echo "  Current origin:  $current_source  (origin drift detected)"
    echo "  Status:          Lock file and origin do not match"
    return 1
}

select_openbmc_repo_url() {
    if [[ -n "$OPENBMC_REPO_URL" ]]; then
        if ! is_valid_repo_url "$OPENBMC_REPO_URL"; then
            error "Invalid OpenBMC repository URL: $OPENBMC_REPO_URL"
            error "Supported formats: https://, http://, ssh://, git://, git@"
            exit 1
        fi
        return 0
    fi

    if [[ -n "${OB_OPENBMC_URL:-}" ]]; then
        OPENBMC_REPO_URL="$OB_OPENBMC_URL"
        if ! is_valid_repo_url "$OPENBMC_REPO_URL"; then
            error "Invalid OpenBMC repository URL from OB_OPENBMC_URL: $OPENBMC_REPO_URL"
            exit 1
        fi
        return 0
    fi

    while true; do
        echo ""
        echo "Select the OpenBMC repository to download:"
        echo "  1) Community OpenBMC (GitHub.com)"
        echo "       equivalent: ob init --obmc-url $DEFAULT_OPENBMC_REPO_URL"
        echo "  2) Custom OpenBMC repository URL"
        echo "       equivalent: ob init --obmc-url <your-repo-url>"
        if ! read -r -p "Choose [1-2]: " selection; then
            error "Unable to read repository source selection from stdin."
            error "Use --obmc-url <url> or set OB_OPENBMC_URL in non-interactive mode."
            exit 1
        fi

        case "$selection" in
            1|"")
                OPENBMC_REPO_URL="$DEFAULT_OPENBMC_REPO_URL"
                SOURCE_LABEL="community"
                return 0
                ;;
            2)
                if ! read -r -p "Enter the full repository URL: " OPENBMC_REPO_URL; then
                    error "Unable to read custom repository URL from stdin."
                    error "Use --obmc-url <url> or set OB_OPENBMC_URL in non-interactive mode."
                    exit 1
                fi
                if is_valid_repo_url "$OPENBMC_REPO_URL"; then
                    SOURCE_LABEL="custom"
                    return 0
                fi
                warn "Invalid repository URL. Please enter a full URL such as https://example.com/openbmc.git"
                ;;
            *)
                warn "Invalid selection: $selection"
                ;;
        esac
    done
}

detect_harness_root() {
    local script_dir
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    HARNESS_ROOT="$script_dir"
    WORKSPACE_DIR="$HARNESS_ROOT/workspace"
    OPENBMC_DIR="$WORKSPACE_DIR/openbmc"
    BUILD_DIR="$OPENBMC_DIR/build/$MACHINE"
    SRC_DIR="$WORKSPACE_DIR/src/$MACHINE"
    CONFIGS_DIR="$WORKSPACE_DIR/configs"
    SOURCE_LOCK_FILE="$CONFIGS_DIR/openbmc-source.lock"
    verbose "HARNESS_ROOT=$HARNESS_ROOT"
    verbose "WORKSPACE_DIR=$WORKSPACE_DIR"
    verbose "MACHINE=$MACHINE"
}

# Capture `source setup` (no args) output, extract available machine names
list_available_machines() {
    [[ -d "$OPENBMC_DIR/.git" ]] || return 0
    local raw
    raw=$(cd "$OPENBMC_DIR" && set +u; source setup 2>&1 || true)
    # setup prints "Use one of:" followed by multi-column machine names
    echo "$raw" \
      | sed -n '/Use one of:/,$p' \
      | tail -n +2 \
      | tr -s ' \t' '\n' \
      | sed '/^$/d' \
      | sort -u
}

# Print supported machine list (passthrough for readability)
print_available_machines() {
    local machines
    machines=$(list_available_machines)
    if [[ -z "$machines" ]]; then
        warn "No machines found. The OpenBMC main repository may be incomplete."
        warn "Try updating it: cd $OPENBMC_DIR && git pull"
        return 0
    fi
    info "Available machines in this repository:"
    local term_cols
    term_cols=$(tput cols 2>/dev/null) || term_cols=80
    echo "$machines" | column -c "$term_cols" 2>/dev/null || echo "$machines"
}

require_openbmc_repo() {
    if [[ -d "$OPENBMC_DIR/.git" ]]; then
        step_header "Step 2/8: Preparing OpenBMC main repository..."
        info "Main repository already exists at $OPENBMC_DIR — skipping clone."
        return 0
    fi
    info "No OpenBMC main repository found at $OPENBMC_DIR."
    info "A small main repository must be cloned first to list/validate machines (a few minutes)."
    clone_openbmc
}

resolve_machine() {
    local machines
    machines=$(list_available_machines)

    # Build numbered machine list
    local -a machine_arr=()
    while IFS= read -r line; do
        [[ -n "$line" ]] && machine_arr+=("$line")
    done <<< "$machines"

    # Fast path: machine specified and valid
    if [[ -n "$MACHINE" ]] && echo "$machines" | grep -qx -- "$MACHINE"; then
        print_available_machines
        info "Machine '$MACHINE' confirmed."
        return 0
    fi

    if [[ -n "$MACHINE" ]]; then
        warn "Machine '$MACHINE' is not in the available list."
    else
        warn "No machine specified."
    fi

    if [[ ! -t 0 ]]; then
        error "No valid machine and no interactive terminal. Pass a valid machine: ob init <machine>"
        exit 1
    fi

    # Print numbered list in columns (adapt to terminal width)
    info "Available machines (enter number or name):"
    local total=${#machine_arr[@]}
    local idx_width=${#total}
    local term_cols
    term_cols=$(tput cols 2>/dev/null) || term_cols=80
    local i=0
    {
        for m in "${machine_arr[@]}"; do
            i=$((i + 1))
            printf "  %${idx_width}d) %s\n" "$i" "$m"
        done
    } | column -c "$term_cols" 2>/dev/null

    local selected
    local chosen=""
    while true; do
        if ! read -r -p "Enter number or machine name: " selected; then
            error "Unable to read machine selection from stdin."
            exit 1
        fi
        # Try as number first
        if [[ "$selected" =~ ^[0-9]+$ ]]; then
            if [[ "$selected" -ge 1 && "$selected" -le "${#machine_arr[@]}" ]]; then
                chosen="${machine_arr[$((selected - 1))]}"
                MACHINE="$chosen"
                info "Machine '$MACHINE' confirmed."
                return 0
            fi
            warn "Number out of range (1-${#machine_arr[@]}): $selected"
            continue
        fi
        # Try as name
        if echo "$machines" | grep -qx -- "$selected"; then
            MACHINE="$selected"
            info "Machine '$MACHINE' confirmed."
            return 0
        fi
        warn "Invalid machine: $selected"
    done
}

prerequisites_check() {
    step_header "Step 1/8: Checking prerequisites..."

    # OS check
    if [[ "$(uname -s)" != "Linux" ]]; then
        error "This script must run on Linux. Current OS: $(uname -s)"
        exit 1
    fi
    verbose "OS: $(uname -s) OK"

    # Tool check
    for tool in git python3; do
        if ! command -v "$tool" &>/dev/null; then
            error "Required tool not found: $tool"
            exit 1
        fi
        verbose "Tool: $tool OK"
    done

    # Network check (best-effort)
    if command -v curl &>/dev/null; then
        local http_code
        http_code=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout 5 https://github.com 2>/dev/null || echo "000")
        if [[ "$http_code" != "200" && "$http_code" != "301" && "$http_code" != "302" ]]; then
            warn "github.com may not be reachable (HTTP $http_code). Clone may fail."
        else
            verbose "Network: github.com reachable (HTTP $http_code)"
        fi
    fi

    # Disk space check (rough estimate: ~200 MB per repo × ~110 repos + main repo + build)
    if [[ -d "$WORKSPACE_DIR" ]]; then
        local avail_mb
        avail_mb=$(df -BM "$WORKSPACE_DIR" 2>/dev/null | tail -1 | awk '{print $4}' | tr -d 'M')
        if [[ -n "$avail_mb" ]] && [[ "$avail_mb" -lt 25000 ]]; then
            warn "Only ${avail_mb}MB free disk space. ob init typically needs 20-30 GB."
            warn "If download fails due to disk space, free up space and re-run."
        fi
    fi

    info "Prerequisites OK."
}

clone_openbmc() {
    step_header "Step 2/8: Preparing OpenBMC main repository..."

    verify_source

    if [[ -d "$OPENBMC_DIR/.git" ]]; then
        info "Main repository already exists at $OPENBMC_DIR — skipping clone."
        info "To update manually: cd $OPENBMC_DIR && git pull"
        return 0
    fi

    select_openbmc_repo_url
    info "Downloading the small OpenBMC main repository (used to list machines, ~a few minutes)."
    info "Cloning $OPENBMC_REPO_URL -> $OPENBMC_DIR"
    if [[ "$DRY_RUN" -eq 1 ]]; then
        info "[DRY-RUN] Would run: git clone $OPENBMC_REPO_URL $OPENBMC_DIR"
        return 0
    fi

    mkdir -p "$WORKSPACE_DIR"
    if ! git clone "$OPENBMC_REPO_URL" "$OPENBMC_DIR"; then
        error "Failed to clone openbmc main repository."
        exit 1
    fi
    write_source_lock
    info "Main repository cloned successfully."
}

init_bitbake_env() {
    step_header "Step 3/8: Initializing bitbake environment for machine=$MACHINE..."

    if [[ "$DRY_RUN" -eq 1 ]]; then
        info "[DRY-RUN] Would run: cd $OPENBMC_DIR && source setup $MACHINE $BUILD_DIR"
        return 0
    fi

    cd "$OPENBMC_DIR"

    # Use OpenBMC's official `source setup <machine>` to initialize the build environment.
    # This handles TEMPLATECONF, bblayers.conf, and local.conf correctly.
    # Temporarily disable nounset — setup sources oe-init-build-env which references unset vars.
    local prev_opts
    prev_opts=$(set +o | grep nounset)
    set +u
    # shellcheck disable=SC1091
    source setup "$MACHINE" "$BUILD_DIR"
    eval "$prev_opts"

    # Verify build dir was created
    if [[ ! -f "$BUILD_DIR/conf/local.conf" ]]; then
        error "local.conf not found after source setup. Something went wrong."
        exit 1
    fi

    ensure_bootstrap_local_conf

    # Pre-create DL_DIR and SSTATE_DIR so bitbake sanity checks don't fail
    # when externalsrc-*.inc references them (injected later in Step 7)
    if [[ -f "$BUILD_DIR/conf/externalsrc-$MACHINE.inc" ]]; then
        mkdir -p "$WORKSPACE_DIR/downloads" "$WORKSPACE_DIR/sstate-cache"

        # Fix legacy .inc files that use ${TOPDIR}/../../../.. relative paths.
        # Bitbake internally prepends '\/' to these resolved paths, causing mkdir
        # to create a spurious '\' directory under the build dir (e.g. build/romulus/\/).
        # Replace with absolute paths to prevent this.
        local inc_file="$BUILD_DIR/conf/externalsrc-$MACHINE.inc"
        if grep -q '\${TOPDIR}/\.\./\.\./\.\./downloads' "$inc_file" 2>/dev/null; then
            verbose "Fixing DL_DIR/SSTATE_DIR in existing $inc_file (relative -> absolute)"
            python3 -c "
import sys
content = open('$inc_file').read()
content = content.replace(
    'DL_DIR = \"\\\${TOPDIR}/../../../downloads\"',
    'DL_DIR = \"$WORKSPACE_DIR/downloads\"'
)
content = content.replace(
    'SSTATE_DIR = \"\\\${TOPDIR}/../../../sstate-cache\"',
    'SSTATE_DIR = \"$WORKSPACE_DIR/sstate-cache\"'
)
open('$inc_file', 'w').write(content)
"
        fi

        # Clean up spurious '\' directory that may have been created by a previous
        # run with relative-path DL_DIR/SSTATE_DIR (bitbake '\/' escaping bug)
        if [[ -d "$BUILD_DIR/"'\\' ]]; then
            warn "Removing spurious escaped directory under $BUILD_DIR"
            rm -rf "$BUILD_DIR/"'\\'
        fi
    fi

    info "Bitbake environment initialized. Build dir: $BUILD_DIR"
}

generate_dep_graph() {
    step_header "Step 4/8: Generating dependency graph..."

    if [[ "$DRY_RUN" -eq 1 ]]; then
        info "[DRY-RUN] Would run: bitbake -g obmc-phosphor-image"
        info "[DRY-RUN] Would run: python3 parse_bitbake_deps.py (per-recipe bitbake -e queries)"
        return 0
    fi

    cd "$OPENBMC_DIR"

    # Re-enter build environment (needed after cd)
    local prev_opts
    prev_opts=$(set +o | grep nounset)
    set +u
    # shellcheck disable=SC1091
    source setup "$MACHINE" "$BUILD_DIR" 2>/dev/null
    eval "$prev_opts"

    # Generate dependency graph to get pn-buildlist
    info "Running bitbake -g obmc-phosphor-image"
    info "This step takes 5-10 minutes (bitbake -g + per-recipe metadata queries)..."
    if ! bitbake -g obmc-phosphor-image; then
        error "bitbake -g failed. Check machine name and bitbake environment."
        exit 1
    fi

    # Parse dependencies: Python script queries bitbake -e per recipe.
    # Write to a temp file first, then atomically rename on success.
    # This prevents ctrl+C from leaving deps.json empty (shell `>` truncates immediately).
    local deps_json="$BUILD_DIR/deps.json"
    local deps_json_tmp="$BUILD_DIR/deps.json.tmp"
    info "Parsing dependency graph (querying per-recipe SRC_URI/SRCREV)..."
    if ! python3 "$HARNESS_ROOT/tools/parse_bitbake_deps.py" \
        --pn-buildlist "$BUILD_DIR/pn-buildlist" \
        --machine "$MACHINE" \
        > "$deps_json_tmp"; then
        rm -f "$deps_json_tmp"
        error "Failed to parse bitbake dependency graph."
        exit 1
    fi
    mv "$deps_json_tmp" "$deps_json"

    local dep_count
    dep_count=$(python3 -c "import json; print(len(json.load(open('$deps_json'))))")
    info "Found $dep_count git-based sub-repositories."
}

clone_sub_repos() {
    # SAFETY: This function is incremental.
    #   - If a repo dir exists with .git, it does 'git fetch' instead of clone.
    #   DO NOT delete src/<machine>/ before re-running ob init.
    #   Only delete the specific failed repo dirs you want to retry.
    #   Deleting all repos wastes hours of download time.
    step_header "Step 5/8: Cloning sub-repositories..."

    local deps_json="$BUILD_DIR/deps.json"

    if [[ "$DRY_RUN" -eq 1 ]]; then
        info "[DRY-RUN] Would clone/fetch repositories listed in $deps_json"
        return 0
    fi

    if [[ ! -f "$deps_json" ]]; then
        error "deps.json not found. Previous step may have failed."
        exit 1
    fi

    mkdir -p "$SRC_DIR"

    # Read each repo from deps.json
    local total failed=0
    total=$(python3 -c "import json; print(len(json.load(open('$deps_json'))))")
    local current=0

    while IFS= read -r entry; do
        current=$((current + 1))
        local name srcrev clone_url branch
        name=$(echo "$entry" | python3 -c "import sys,json; print(json.load(sys.stdin)['name'])")
        srcrev=$(echo "$entry" | python3 -c "import sys,json; print(json.load(sys.stdin)['srcrev'])")
        clone_url=$(echo "$entry" | python3 -c "import sys,json; print(json.load(sys.stdin)['clone_url'])")
        # Strip surrounding quotes from branch (bitbake may emit branch=\"main\")
        branch=$(echo "$entry" | python3 -c "import sys,json; print(json.load(sys.stdin).get('branch',''))" | tr -d '\"' | tr -d "'")

        local local_path="$SRC_DIR/$name"
        info "[$current/$total] Processing: $name"

        if [[ -d "$local_path/.git" ]]; then
            verbose "Fetching updates for $name..."
            if ! git -C "$local_path" fetch --all 2>/dev/null; then
                warn "Failed to fetch $name, continuing with existing state."
            fi
        else
            # Build clone flags: use --single-branch when branch is known
            local clone_flags=()
            if [[ -n "$branch" ]]; then
                clone_flags+=(--single-branch --branch "$branch")
            fi

            verbose "Cloning $clone_url -> $local_path"
            if ! git clone "${clone_flags[@]}" "$clone_url" "$local_path" 2>/dev/null; then
                # Retry 1: shallow clone (faster for large repos like linux, binutils)
                warn "Full clone failed for $name, retrying with shallow clone..."
                rm -rf "$local_path" 2>/dev/null
                local shallow_flags=(--depth=1)
                if [[ -n "$branch" ]]; then
                    shallow_flags+=(--single-branch --branch "$branch")
                fi
                if ! git clone "${shallow_flags[@]}" "$clone_url" "$local_path" 2>/dev/null; then
                    # Retry 2: branch may not exist (e.g. fmt renamed master→main),
                    # try shallow clone without --single-branch constraint
                    if [[ -n "$branch" ]]; then
                        warn "Branch '$branch' not found for $name, retrying without branch constraint..."
                        rm -rf "$local_path" 2>/dev/null
                        if ! git clone --depth=1 "$clone_url" "$local_path" 2>/dev/null; then
                            error "Failed to clone $name from $clone_url"
                            STATUS_FAILED+=("$name (clone failed — network error or server unreachable)")
                            failed=$((failed + 1))
                            continue
                        fi
                        warn "$name cloned shallow without branch constraint (full git history unavailable)"
                        STATUS_SHALLOW+=("$name")
                    else
                        error "Failed to clone $name from $clone_url"
                        STATUS_FAILED+=("$name (clone failed — network error or server unreachable)")
                        failed=$((failed + 1))
                        continue
                    fi
                fi
                # Retry 1 succeeded — check if repo is actually shallow
                if git -C "$local_path" rev-parse --is-shallow-repository 2>/dev/null | grep -q true; then
                    STATUS_SHALLOW+=("$name")
                fi
            fi
        fi

        # Check if srcrev is usable (skip placeholder values)
        # bitbake may return "INVALID" for named SRCREV components that weren't resolved
        local skip_checkout=0
        if [[ -z "$srcrev" || "$srcrev" == "\${AUTOREV}" || "$srcrev" == "AUTOINC" || "$srcrev" == "INVALID" ]]; then
            skip_checkout=1
            STATUS_UNPINNED+=("$name (srcrev=$srcrev)")
        fi

        # Checkout to specified commit
        if [[ "$skip_checkout" -eq 0 ]]; then
            verbose "Checking out $name to $srcrev"
            if ! git -C "$local_path" checkout "$srcrev" 2>/dev/null; then
                # Try fetching all remotes first
                warn "Commit $srcrev not found locally for $name, fetching..."
                git -C "$local_path" fetch --all 2>/dev/null || true
                if ! git -C "$local_path" checkout "$srcrev" 2>/dev/null; then
                    warn "Could not checkout $name to $srcrev. Skipping."
                    STATUS_FAILED+=("$name (checkout failed — commit lost to upstream force-push, try latest HEAD)")
                    failed=$((failed + 1))
                    continue
                fi
            fi
        else
            verbose "Skipping checkout for $name (srcrev=$srcrev, using branch HEAD)"
        fi

        STATUS_SUCCESS+=("$name")
    done < <(python3 -c "
import json, sys
for item in json.load(open('$deps_json')):
    json.dump(item, sys.stdout)
    print()
")

    info "Sub-repos: ${#STATUS_SUCCESS[@]} succeeded, $failed failed."
}

generate_lockfile() {
    step_header "Step 6/8: Generating lockfile..."

    local lockfile="$CONFIGS_DIR/$MACHINE.lock"

    if [[ "$DRY_RUN" -eq 1 ]]; then
        info "[DRY-RUN] Would write lockfile to $lockfile"
        return 0
    fi

    mkdir -p "$CONFIGS_DIR"

    local openbmc_commit
    openbmc_commit=$(git -C "$OPENBMC_DIR" rev-parse HEAD)

    # Build lockfile JSON
    python3 -c "
import json, datetime
deps = json.load(open('$BUILD_DIR/deps.json'))
lockfile = {
    'machine': '$MACHINE',
    'generated_at': datetime.datetime.now().astimezone().isoformat(),
    'openbmc_commit': '$openbmc_commit',
    'target_image': 'obmc-phosphor-image',
    'sub_repos': []
}
for dep in deps:
    lockfile['sub_repos'].append({
        'name': dep['name'],
        'src_uri': dep['src_uri'],
        'srcrev': dep['srcrev'],
        'local_path': 'workspace/src/$MACHINE/' + dep['name'],
        'recipe': dep['recipe']
    })
with open('$lockfile', 'w') as f:
    json.dump(lockfile, f, indent=2, ensure_ascii=False)
    f.write('\n')
"

    if [[ -f "$lockfile" ]]; then
        info "Overwriting existing lockfile: $lockfile"
    fi

    info "Lockfile written to $lockfile"
}

inject_externalsrc() {
    step_header "Step 7/8: Injecting externalsrc configuration..."

    local conf_dir="$BUILD_DIR/conf"
    local inc_file="$conf_dir/externalsrc-$MACHINE.inc"
    local local_conf="$conf_dir/local.conf"

    if [[ "$DRY_RUN" -eq 1 ]]; then
        info "[DRY-RUN] Would generate $inc_file"
        info "[DRY-RUN] Would add include to $local_conf"
        return 0
    fi

    local timestamp
    timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    # Backup existing .inc file (keep only the most recent backup)
    if [[ -f "$inc_file" ]]; then
        # Remove old backups before creating new one
        rm -f "${inc_file}".bak.* 2>/dev/null || true
        cp "$inc_file" "${inc_file}.bak.$(date +%Y%m%d%H%M%S)"
        info "Previous .inc backed up (old backups cleaned up)"
    fi

    # Generate .inc file
    {
        echo "# Auto-generated by ob init $MACHINE at $timestamp"
        echo "# Do not edit manually. Re-run 'ob init $MACHINE' to regenerate."
        echo ""

        # Shared download and sstate cache across all machines
        # NOTE: Must use absolute paths, not ${TOPDIR}/../../../.. relative paths.
        # Bitbake internally prepends '\/' to relative-resolved paths, which causes
        # mkdir to create a spurious '\' directory under the build dir.
        echo "# Shared across machines to avoid re-downloading/re-building"
        echo "DL_DIR = \"$WORKSPACE_DIR/downloads\""
        echo "SSTATE_DIR = \"$WORKSPACE_DIR/sstate-cache\""
        echo ""

        # Ensure DL_DIR and SSTATE_DIR directories exist (bitbake sanity check requires them)
        mkdir -p "$WORKSPACE_DIR/downloads" "$WORKSPACE_DIR/sstate-cache"

        # Read deps to generate EXTERNALSRC lines
        python3 -c "
import json
deps = json.load(open('$BUILD_DIR/deps.json'))
for dep in deps:
    name = dep['name']
    recipe = dep['recipe']
    local_path = '$SRC_DIR/' + name
    print(f'EXTERNALSRC_pn-{recipe} = \"{local_path}\"')
    print(f'EXTERNALSRC_BUILD_pn-{recipe} = \"{local_path}\"')
    print()
"
    } > "$inc_file"

    info "Generated $inc_file"

    # Add include to local.conf if not already present
    local include_line="include externalsrc-$MACHINE.inc"

    if grep -qF "$include_line" "$local_conf"; then
        verbose "Include line already exists in local.conf, skipping."
    else
        # Backup local.conf
        cp "$local_conf" "${local_conf}.bak.$(date +%Y%m%d%H%M%S)"
        echo "" >> "$local_conf"
        echo "$include_line" >> "$local_conf"
        info "Added '$include_line' to local.conf"
    fi
}

print_report() {
    step_header "Step 8/8: Status Report"

    local report_file="$CONFIGS_DIR/$MACHINE.report.txt"

    # Emit report to both terminal and file via tee
    {
        echo "============================================"
        echo "Machine:    $MACHINE"
        echo "Main repo:  $OPENBMC_DIR"
        echo "Build dir:  $BUILD_DIR"
        echo "Source dir: $SRC_DIR"
        echo "Lockfile:   $CONFIGS_DIR/$MACHINE.lock"
        echo "Ext. conf:  $BUILD_DIR/conf/externalsrc-$MACHINE.inc"
        echo ""

        # --- Success ---
        echo "Sub-repos cloned: ${#STATUS_SUCCESS[@]}"
        for name in "${STATUS_SUCCESS[@]}"; do
            echo "  [OK] $name"
        done
        echo ""

        # --- Shallow repos ---
        if [[ ${#STATUS_SHALLOW[@]} -gt 0 ]]; then
            echo "Shallow-cloned repos (limited git history):"
            for entry in "${STATUS_SHALLOW[@]}"; do
                echo "  [SHALLOW] $entry"
            done
            echo ""
            echo "[WARN] Shallow repos have limited git history. To get full history:"
            echo "  git -C src/$MACHINE/<repo> fetch --unshallow"
            echo ""
        fi

        # --- Unpinned repos ---
        if [[ ${#STATUS_UNPINNED[@]} -gt 0 ]]; then
            echo "Unpinned repos (using branch HEAD, version may drift):"
            for entry in "${STATUS_UNPINNED[@]}"; do
                echo "  [UNPINNED] $entry"
            done
            echo ""
            echo "[WARN] Unpinned repos are NOT locked to a specific commit."
            echo "[WARN] Re-running ob init may change their version."
            echo ""
        fi

        # --- Failed repos ---
        if [[ ${#STATUS_FAILED[@]} -gt 0 ]]; then
            echo "Failed repos: ${#STATUS_FAILED[@]}"
            for entry in "${STATUS_FAILED[@]}"; do
                echo "  [FAIL] $entry"
            done
            echo ""
            echo "[WARN] Troubleshooting guide:"
            echo "  A) Network flakiness      -> retry: rm -rf src/$MACHINE/<repo> && ob init $MACHINE"
            echo "  B) Branch not found       -> upstream renamed branch; ob will auto-retry without branch"
            echo "  C) Commit lost            -> upstream force-push; use latest HEAD manually"
            echo "  D) Server network block   -> specific domains (e.g. infradead.org) may be unreachable"
            echo "  E) srcrev placeholder     -> AUTOREV/INVALID; will use branch HEAD (expected)"
            echo ""
        fi

        # --- Elapsed time ---
        local elapsed_seconds=$SECONDS
        local elapsed_min=$((elapsed_seconds / 60))
        local elapsed_sec=$((elapsed_seconds % 60))
        echo "Total time: ${elapsed_min}m ${elapsed_sec}s"
        echo "============================================"
    } | tee "$report_file"

    echo ""
    info "Report saved to: $report_file"
    info "Next steps:"
    echo "  cd $OPENBMC_DIR"
    echo "  source setup $MACHINE"
    echo "  bitbake obmc-phosphor-image"
    echo ""
    info "Re-running ob init is safe — it is incremental and idempotent."
    echo "Safe to Ctrl+C at any time; re-run will resume from where it left off."
}

# === Main ===
main() {
    SECONDS=0
    show_logo
    parse_args "$@"
    detect_harness_root

    if [[ "$COMMAND" == "status" ]]; then
        cmd_status
        return 0
    fi

    prerequisites_check
    require_openbmc_repo
    resolve_machine

    # Re-derive paths (machine may have changed via interactive resolve_machine)
    BUILD_DIR="$OPENBMC_DIR/build/$MACHINE"
    SRC_DIR="$WORKSPACE_DIR/src/$MACHINE"

    # --- Detect fresh run vs incremental re-run ---
    local is_rerun=0
    if [[ -d "$SRC_DIR" ]] && [[ $(ls -d "$SRC_DIR"/*/ 2>/dev/null | wc -l) -gt 0 ]]; then
        is_rerun=1
    fi
    if [[ -d "$BUILD_DIR/conf" ]] && [[ -f "$BUILD_DIR/conf/local.conf" ]]; then
        is_rerun=1
    fi

    if [[ "$is_rerun" -eq 1 ]]; then
        local existing_repos=0
        existing_repos=$(find "$SRC_DIR" -maxdepth 2 -name ".git" -type d 2>/dev/null | wc -l)
        echo ""
        info "INCREMENTAL RUN DETECTED for machine=$MACHINE"
        if [[ "$existing_repos" -gt 0 ]]; then
            info "  Existing repos: $existing_repos under $SRC_DIR"
        fi
        if [[ -f "$BUILD_DIR/conf/local.conf" ]]; then
            info "  Build config: $BUILD_DIR/conf/ already exists"
        fi
        info "  Actions: fetch updates for existing repos, clone missing ones, regenerate config"
        echo ""
    else
        echo ""
        info "FRESH RUN — initializing OpenBMC environment for machine=$MACHINE"
        echo ""
        warn "============================================================"
        warn " Machine '$MACHINE' confirmed — about to fetch its sub-repos."
        warn " Download size : ~20-30 GB"
        warn " Estimated time: 20-60 minutes"
        warn " Resumable     : safe to Ctrl+C; re-run resumes incrementally."
        warn "============================================================"
        echo ""
    fi

    init_bitbake_env
    generate_dep_graph
    clone_sub_repos
    generate_lockfile
    inject_externalsrc
    print_report
}

if [[ -z "${OB_NO_MAIN:-}" ]]; then
    main "$@"
fi