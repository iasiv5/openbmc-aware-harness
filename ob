# === Functions ===

usage() {
    cat <<EOF
Usage: ob [command] [options] [arguments]

Run without arguments to enter interactive menu mode.

Commands:
  init   [<machine>]    One-click initialize OpenBMC dev environment
  build                 Select an initialized machine and build its image
  status                Show current OpenBMC source binding status

Options:
  -d, --dry-run         Print actions without executing
  -u, --url <url>       Use a custom OpenBMC repository URL
  -v, --verbose         Verbose output
  -h, --help            Show this help

Examples:
  ob init                          # List machines and choose interactively
  ob init romulus                  # Initialize romulus machine
  ob init romulus -d               # Preview what would be done
  ob init romulus --url https://example.com/openbmc.git
EOF
}

parse_args() {
    if [[ $# -lt 1 ]]; then
        COMMAND=""
        return 0
    fi

    # Handle global --help/-h before dispatching to subcommands
    if [[ "$1" == "-h" || "$1" == "--help" ]]; then
        usage
        exit 0
    fi

    COMMAND="$1"
    shift

    case "$COMMAND" in
        init)
            if [[ $# -gt 0 ]] && [[ "$1" != -* ]]; then
                MACHINE="$1"
                shift
            fi
            ;;
        status)
            if [[ $# -gt 0 ]] && [[ "$1" != -* ]]; then
                MACHINE="$1"
                shift
            fi
            ;;
        build)
            # No arguments accepted for build
            ;;
        *)
            error "Unknown command: $COMMAND"
            usage
            exit 1
            ;;
    esac

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -d|-D|--dry-run)    DRY_RUN=1; shift ;;
            -s|-S|--skip-deps)   SKIP_DEPS=1; shift ;;
            -u|-U|--url)
                if [[ $# -lt 2 ]]; then
                    error "Missing value for --url"
                    usage
                    exit 1
                fi
                OPENBMC_REPO_URL="$2"
                shift 2
                ;;
            -v|-V|--verbose)  VERBOSE=1; shift ;;
            -h|-H|--help)     usage; exit 0 ;;
            *)             error "Unknown option: $1"; usage; exit 1 ;;
        esac
    done
}

is_valid_repo_url() {
    local repo_url="$1"
    [[ "$repo_url" =~ ^https?:// ]] || [[ "$repo_url" =~ ^ssh:// ]] || [[ "$repo_url" =~ ^git:// ]] || [[ "$repo_url" =~ ^git@ ]]
}

normalize_repo_url() {
    local repo_url="$1"
    local normalized="$repo_url"
    local host=""
    local path=""

    normalized="${normalized#https://}"
    normalized="${normalized#http://}"
    normalized="${normalized#ssh://}"
    normalized="${normalized#git://}"

    if [[ "$normalized" =~ ^([^@]+)@([^:]+):(.+)$ ]]; then
        host="${BASH_REMATCH[2]}"
        path="${BASH_REMATCH[3]}"
        if [[ "$path" =~ ^([0-9]+)/(.*)$ ]]; then
            normalized="$host/${path#*/}"
        else
            normalized="$host/$path"
        fi
    elif [[ "$normalized" =~ ^([^@]+)@(.+)$ ]]; then
        normalized="${BASH_REMATCH[2]}"
    fi

    if [[ "$normalized" =~ ^\[?([^]/:]+)\]?:(.+)$ ]]; then
        host="${BASH_REMATCH[1]}"
        path="${BASH_REMATCH[2]}"
        if [[ "$path" =~ ^([0-9]+)/(.*)$ ]]; then
            normalized="$host/${path#*/}"
        else
            normalized="$host/$path"
        fi
    fi

    normalized="${normalized%/}"
    normalized="${normalized%.git}"

    if [[ "$normalized" =~ ^([^/]+)/(.*)$ ]]; then
        local host="${BASH_REMATCH[1]}"
        local path="${BASH_REMATCH[2]}"
        host="${host,,}"
        path="${path,,}"
        normalized="$host/$path"
    else
        normalized="${normalized,,}"
    fi

    echo "$normalized"
}

write_source_lock() {
    local normalized_source
    local timestamp

    normalized_source="$(normalize_repo_url "$OPENBMC_REPO_URL")"
    timestamp="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

    if [[ "$DRY_RUN" -eq 1 ]]; then
        info "[DRY-RUN] Would write source lock to $SOURCE_LOCK_FILE"
        info "[DRY-RUN]   normalized_source=$normalized_source"
        info "[DRY-RUN]   origin_url=$OPENBMC_REPO_URL"
        info "[DRY-RUN]   source_label=$SOURCE_LABEL"
        return 0
    fi

    mkdir -p "$CONFIGS_DIR"

    cat > "$SOURCE_LOCK_FILE" <<EOF
# openbmc source lock — auto-generated by 'ob init', do not edit by hand
normalized_source=$normalized_source
origin_url=$OPENBMC_REPO_URL
source_label=$SOURCE_LABEL
machine_first_init=$MACHINE
created_at=$timestamp
EOF
}

ensure_bootstrap_local_conf() {
    local local_conf="$BUILD_DIR/conf/local.conf"

    if [[ ! -f "$local_conf" ]]; then
        error "local.conf not found at $local_conf"
        exit 1
    fi

    # Detect GitLab IP for recipes that use ${GITLAB_IP} in SRC_URI.
    # Priority: (1) github-gitlab-url.sh (2) git remote origin URL (3) empty (skip)
    local gitlab_ip=""
    local _rt_script=""
    local _remote_url=""
    for _candidate in "$OPENBMC_DIR"/meta-*/git-mirror-url.sh \
                      "$OPENBMC_DIR"/meta-*/github-gitlab-url.sh; do
        if [[ -f "$_candidate" ]]; then _rt_script="$_candidate"; break; fi
    done
    if [[ -f "$_rt_script" ]]; then
        gitlab_ip=$(grep -oP '^(GITLAB_IP|GIT_MIRROR_HOST)=["'"'"']?\K[^"'"'"'\s]+' "$_rt_script" 2>/dev/null | head -1 || true)
    fi
    if [[ -z "$gitlab_ip" && -f "$OPENBMC_DIR/.git/config" ]]; then
        _remote_url=$(git -C "$OPENBMC_DIR" remote get-url origin 2>/dev/null || true)
        if [[ "$_remote_url" == git@* ]]; then
            gitlab_ip=$(echo "$_remote_url" | sed -E 's/^git@([^:]+):.*/\1/')
        elif [[ "$_remote_url" == http://* || "$_remote_url" == https://* ]]; then
            gitlab_ip=$(echo "$_remote_url" | sed -E 's#^https?://([^/:]+).*#\1#')
        fi
    fi

    # If the remote uses SSH, but recipes reference the host via protocol=https,
    # configure git to rewrite HTTPS URLs to SSH automatically.
    # This handles GitLab servers where HTTPS is unavailable or requires auth
    # that isn't configured in recipes, while SSH key access works out of the box.
    # Only set when missing — user can override manually if needed.
    if [[ -n "$gitlab_ip" ]]; then
        local _existing_rewrite=""
        _existing_rewrite=$(git config --global --get "url.git@${gitlab_ip}:.insteadOf" 2>/dev/null || true)
        if [[ -z "$_existing_rewrite" ]]; then
            git config --global "url.git@${gitlab_ip}:.insteadOf" "https://${gitlab_ip}/"
            info "Configured git insteadOf: https://${gitlab_ip}/ → git@${gitlab_ip} (SSH rewrite for recipe fetches)"
        else
            verbose "Git insteadOf for ${gitlab_ip} already configured: ${_existing_rewrite} → git@${gitlab_ip}:"
        fi
    fi

    # Add include to local.conf if not already present.
    # The .inc file (managed by generate_build_config) contains all ob init settings.
    local include_line="include externalsrc-$MACHINE.inc"

    if grep -qF "$include_line" "$local_conf"; then
        verbose "Include line already exists in local.conf, skipping."
    else
        cp "$local_conf" "${local_conf}.bak.$(date +%Y%m%d%H%M%S)"
        echo "" >> "$local_conf"
        echo "$include_line" >> "$local_conf"
        info "Added '$include_line' to local.conf"
    fi

    verbose "Ensured ob init local.conf settings in $local_conf"
}

read_lock_field() {
    local key="$1"

    if [[ ! -f "$SOURCE_LOCK_FILE" ]]; then
        return 1
    fi

    local line
    line=$(grep -E "^${key}=" "$SOURCE_LOCK_FILE" | head -n 1 || true)
    if [[ -z "$line" ]]; then
        return 1
    fi

    echo "${line#*=}"
}

verify_source() {
    local lock_source=""
    local current_origin=""
    local current_source=""
    local requested_url="$OPENBMC_REPO_URL"
    local requested_source=""
    local lock_label=""

    if [[ ! -d "$OPENBMC_DIR/.git" ]]; then
        return 0
    fi

    if [[ ! -f "$SOURCE_LOCK_FILE" ]]; then
        current_origin=$(git -C "$OPENBMC_DIR" remote get-url origin 2>/dev/null || true)
        if [[ -n "$current_origin" ]]; then
            OPENBMC_REPO_URL="$current_origin"
            SOURCE_LABEL=""
            write_source_lock
            if [[ -n "$requested_url" ]]; then
                requested_source=$(normalize_repo_url "$requested_url")
                current_source=$(normalize_repo_url "$current_origin")
                if [[ "$requested_source" != "$current_source" ]]; then
                    error "OpenBMC main repository source conflict detected."
                    error "  Current harness source: $current_source"
                    error "  Requested source:       $requested_source"
                    error "A harness may only bind to one OpenBMC main repository source."
                    error "To use a different source, copy ob-harness and run ob init in the new copy."
                    exit 1
                fi
            fi
            OPENBMC_REPO_URL="$requested_url"
        else
            warn "OpenBMC main repository exists but has no origin remote; skipping source lock bootstrap."
        fi
        return 0
    fi

    lock_source=$(read_lock_field normalized_source || true)
    lock_label=$(read_lock_field source_label || true)
    current_origin=$(git -C "$OPENBMC_DIR" remote get-url origin 2>/dev/null || true)

    if [[ -n "$current_origin" ]]; then
        current_source=$(normalize_repo_url "$current_origin")
        if [[ -n "$lock_source" ]] && [[ "$current_source" != "$lock_source" ]]; then
            error "OpenBMC main repository source does not match the lock file."
            error "  Locked source:  $lock_source"
            error "  Actual origin:   $current_source"
            error "Existing openbmc origin and openbmc-source.lock have drifted, likely due to a manual change."
            error "Please verify the main repository source before continuing. If you need a different source, use a separate harness copy."
            exit 1
        fi
    else
        warn "OpenBMC main repository has no origin remote; skipping lock vs origin verification."
    fi

    if [[ -n "$OPENBMC_REPO_URL" ]]; then
        requested_source=$(normalize_repo_url "$OPENBMC_REPO_URL")
        if [[ -n "$lock_source" ]] && [[ "$requested_source" != "$lock_source" ]]; then
            error "OpenBMC main repository source conflict detected."
            error "  Current harness source: $lock_source${lock_label:+  ($lock_label)}"
            error "  Requested source:       $requested_source"
            error "A harness may only bind to one OpenBMC main repository source."
            error "To use a different source, copy ob-harness and run ob init in the new copy."
            exit 1
        fi
    fi

    return 0
}

cmd_status() {
    local lock_exists=0
    local repo_exists=0
    local normalized_source=""
    local origin_url=""
    local source_label=""
    local machine_first_init=""
    local created_at=""
    local current_origin=""
    local current_source=""

    [[ -f "$SOURCE_LOCK_FILE" ]] && lock_exists=1
    [[ -d "$OPENBMC_DIR/.git" ]] && repo_exists=1

    if [[ "$lock_exists" -eq 1 ]]; then
        normalized_source=$(read_lock_field normalized_source || true)
        origin_url=$(read_lock_field origin_url || true)
        source_label=$(read_lock_field source_label || true)
        machine_first_init=$(read_lock_field machine_first_init || true)
        created_at=$(read_lock_field created_at || true)
    fi

    if [[ "$repo_exists" -eq 1 ]]; then
        current_origin=$(git -C "$OPENBMC_DIR" remote get-url origin 2>/dev/null || true)
        if [[ -n "$current_origin" ]]; then
            current_source=$(normalize_repo_url "$current_origin")
        fi
    fi

    echo "OpenBMC main repository binding status"

    if [[ "$lock_exists" -eq 0 ]] && [[ "$repo_exists" -eq 0 ]]; then
        echo "  Status:          Not initialized"
        echo "  Tip:             Run ob init <machine>"
        return 0
    fi

    if [[ "$lock_exists" -eq 0 ]] && [[ "$repo_exists" -eq 1 ]]; then
        echo "  Status:          Repository present without source lock"
        echo "  Current origin:  ${current_source:-<missing origin>}"
        echo "  Tip:             Re-run ob init to bootstrap openbmc-source.lock"
        return 0
    fi

    echo "  Bound source:    $normalized_source${source_label:+  ($source_label)}"
    echo "  Origin URL:      ${origin_url:-<unknown>}"
    echo "  First init:      ${machine_first_init:-<unknown>}  @ ${created_at:-<unknown>}"

    if [[ "$repo_exists" -eq 0 ]]; then
        echo "  Current origin:  Repository missing"
        echo "  Status:          Main repository not cloned or was deleted"
        return 0
    fi

    if [[ -z "$current_origin" ]]; then
        echo "  Current origin:  <missing origin>"
        echo "  Status:          Origin remote missing"
        return 0
    fi

    if [[ "$current_source" == "$normalized_source" ]]; then
        echo "  Current origin:  $current_source  (origin matches)"
        echo "  Status:          OK"
        return 0
    fi

    echo "  Current origin:  $current_source  (origin drift detected)"
    echo "  Status:          Lock file and origin do not match"
    return 1
}

cmd_build() {
    # === Prerequisites ===
    if [[ ! -d "$OPENBMC_DIR/.git" ]]; then
        error "OpenBMC main repository not found at $OPENBMC_DIR"
        error "Run 'ob init' first."
        exit 1
    fi

    if [[ ! -f "$SOURCE_LOCK_FILE" ]]; then
        error "Source lock not found at $SOURCE_LOCK_FILE"
        error "Run 'ob init' first."
        exit 1
    fi

    # === Discover init-done machines ===
    local -a machines=()
    local -a init_times=()
    local -a repo_counts=()

    for init_done_file in "$CONFIGS_DIR"/*.init-done; do
        [[ -f "$init_done_file" ]] || continue
        local mname
        mname=$(basename "$init_done_file" .init-done)
        machines+=("$mname")

        local init_time
        if ! IFS= read -r init_time < "$init_done_file"; then
            init_time="<unknown>"
        fi
        init_times+=("$init_time")

        local lockfile="$CONFIGS_DIR/$mname.lock"
        local repo_count=0
        if [[ -f "$lockfile" ]]; then
            repo_count=$(python3 -c "import json; print(len(json.load(open('$lockfile'))['sub_repos']))" 2>/dev/null || echo "?")
        else
            repo_count="?"
        fi
        repo_counts+=("$repo_count")
    done

    if [[ ${#machines[@]} -eq 0 ]]; then
        step_header "Initialized Machines"
        echo ""
        echo "  (none)"
        echo ""
        error "No machines are ready to build."
        error "Run 'ob init' first to initialize a machine."
        exit 1
    fi

    # === Read main repo info ===
    local lock_origin_url lock_source_label
    lock_origin_url=$(read_lock_field origin_url || echo "<unknown>")
    lock_source_label=$(read_lock_field source_label || echo "")

    # === Display ===
    step_header "OpenBMC Repository"
    echo "  Source : $lock_origin_url${lock_source_label:+ ($lock_source_label)}"
    echo "  Path   : $OPENBMC_DIR"
    echo ""

    step_header "Initialized Machines"

    local total=${#machines[@]}
    local idx_width=${#total}
    local i
    for (( i=0; i<total; i++ )); do
        printf "  %${idx_width}d) %-20s %s    %s repos\n" \
            "$((i + 1))" "${machines[$i]}" "${init_times[$i]}" "${repo_counts[$i]}"
    done

    echo ""
    info "If the machine you want is not listed, run 'init' task or './ob init' first."
    echo ""

    # === Interactive selection ===
    if [[ ! -t 0 ]]; then
        error "No interactive terminal. ob build requires interactive mode."
        exit 1
    fi

    local selected chosen=""
    while true; do
        if ! read -r -p "$(echo -e "${PROMPT_PREFIX} Select a machine to build [1-${total}]: ")" selected; then
            error "Unable to read selection from stdin."
            exit 1
        fi
        if [[ "$selected" =~ ^[0-9]+$ ]]; then
            if [[ "$selected" -ge 1 && "$selected" -le "$total" ]]; then
                chosen="${machines[$((selected - 1))]}"
                break
            fi
            warn "Number out of range (1-${total}): $selected"
            continue
        fi
        warn "Please enter a number (1-${total})"
    done

    MACHINE="$chosen"
    BUILD_DIR="$OPENBMC_DIR/build/$MACHINE"

    echo ""
    info "Selected: $MACHINE"
    info "Target  : obmc-phosphor-image"
    info "Estimated time: 1-4 hours depending on machine and cache state."
    echo ""
    echo "============================================================"
    echo ""
    warn "  You are about to build:  >>> $MACHINE <<<"
    warn "  You are about to build:  >>> $MACHINE <<<"
    warn "  You are about to build:  >>> $MACHINE <<<"
    echo ""
    echo "============================================================"
    echo ""
    while true; do
        if ! read -r -p "$(echo -e "${PROMPT_PREFIX} Type (Y/y) to confirm and start build, (N/n) to cancel: ")" confirm; then
            error "Unable to read confirmation from stdin."
            exit 1
        fi
        case "$confirm" in
            [yY])
                break
                ;;
            [nN])
                warn "Build cancelled by user."
                exit 2
                ;;
            *)
                warn "Invalid input. Please type Y or N."
                ;;
        esac
    done

    # === Re-enter bitbake environment ===
    cd "$OPENBMC_DIR"

    local prev_opts
    prev_opts=$(set +o | grep nounset)
    set +u
    # shellcheck disable=SC1091
    source setup "$MACHINE" "$BUILD_DIR" 2>/dev/null
    eval "$prev_opts"

    # === Run bitbake ===
    echo ""
    step_header "Building $MACHINE"
    info "Running: bitbake obmc-phosphor-image"
    echo ""

    if bitbake obmc-phosphor-image; then
        echo ""
        step_header "Build Succeeded"

        local deploy_dir="$BUILD_DIR/tmp/deploy/images/$MACHINE"
        local image_file="$deploy_dir/obmc-phosphor-image-$MACHINE.static.mtd"

        echo "  Machine : $MACHINE"
        echo "  Image   : $image_file"
        if [[ -f "$image_file" ]]; then
            local image_size
            image_size=$(python3 - "$image_file" <<'PY'
import os
import sys

size = os.path.getsize(sys.argv[1])
units = ["B", "KiB", "MiB", "GiB", "TiB"]
value = float(size)

for unit in units:
    if value < 1024.0 or unit == units[-1]:
        if unit == "B":
            print(f"{int(value)} {unit}")
        elif value >= 10:
            print(f"{value:.0f} {unit}")
        else:
            print(f"{value:.1f} {unit}")
        break
    value /= 1024.0
PY
)
            echo "  Size    : $image_size"
        fi
        echo "  Deploy  : $deploy_dir"
        echo ""
        info "Build completed successfully."
    else
        local bb_exit=$?
        echo ""
        step_header "Build Failed"
        echo ""
        error "bitbake exited with code $bb_exit"
        echo ""
        echo "  BitBake error details are shown above."
        echo ""
        echo "  Common fixes:"
        echo "    1. Re-run:         ob build  -- select same machine -- retry"
        echo "    2. Clean & retry:  cd $OPENBMC_DIR && source setup $MACHINE"
        echo "                       bitbake -c cleansstate <failed-recipe>"
        echo "    3. Full log:       $BUILD_DIR/tmp/log/cooker/$MACHINE/"
        echo ""
        exit "$bb_exit"
    fi
}

select_openbmc_repo_url() {
    if [[ -n "$OPENBMC_REPO_URL" ]]; then
        if ! is_valid_repo_url "$OPENBMC_REPO_URL"; then
            error "Invalid OpenBMC repository URL: $OPENBMC_REPO_URL"
            error "Supported formats: https://, http://, ssh://, git://, git@"
            exit 1
        fi
        return 0
    fi

    if [[ -n "${OB_OPENBMC_URL:-}" ]]; then
        OPENBMC_REPO_URL="$OB_OPENBMC_URL"
        if ! is_valid_repo_url "$OPENBMC_REPO_URL"; then
            error "Invalid OpenBMC repository URL from OB_OPENBMC_URL: $OPENBMC_REPO_URL"
            exit 1
        fi
        return 0
    fi

    while true; do
        echo ""
        echo "Select the OpenBMC source repository:"
        echo "  1) Community (https://github.com/openbmc/openbmc.git)"
        echo "  2) Custom repository URL"
        if ! read -r -p "$(echo -e "${PROMPT_PREFIX} Choose [1-2]: ")" selection; then
            error "Unable to read repository source selection from stdin."
            error "Use --url <url> or set OB_OPENBMC_URL in non-interactive mode."
            exit 1
        fi

        case "$selection" in
            1|"")
                OPENBMC_REPO_URL="$DEFAULT_OPENBMC_REPO_URL"
                SOURCE_LABEL="community"
                return 0
                ;;
            2)
                if ! read -r -p "$(echo -e "${PROMPT_PREFIX} Enter the full repository URL: ")" OPENBMC_REPO_URL; then
                    error "Unable to read custom repository URL from stdin."
                    error "Use --url <url> or set OB_OPENBMC_URL in non-interactive mode."
                    exit 1
                fi
                if is_valid_repo_url "$OPENBMC_REPO_URL"; then
                    SOURCE_LABEL="custom"
                    return 0
                fi
                warn "Invalid repository URL. Please enter a full URL such as https://example.com/openbmc.git"
                ;;
            *)
                warn "Invalid selection: $selection"
                ;;
        esac
    done
}

